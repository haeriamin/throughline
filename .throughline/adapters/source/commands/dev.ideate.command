ns = dev
cmd = ideate
persona = analyst
description = Brainstorm options before building — read-only ideation that explores approaches, trade-offs, and risks, then recommends a direction
argument_hint = "<rough idea or problem>" [target-id]
runbook_steps = purpose, preconditions, steps, exit criteria, handoff, failure modes
final_note = This step is read-only and conversational: explore options, ask the questions that matter, recommend a direction, and write the ideation note. Do **not** write a spec, create a branch, or touch target source — that begins later with the specify command. Bootstrap lightly (Principle II); append the outcome to `wiki/log.md` (Principle VII).
