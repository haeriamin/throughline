# Source of truth for the Reviewer persona metadata. Behavioral body: source/agents/reviewer.agent.md.
# Rendered by tools/convert; edit source, not generated adapter files.name = reviewer
display = Reviewer
tools = Read, Glob, Grep, Bash, Write
codex_sandbox = workspace-write
codex_sandbox_comment = writes ONLY <target>/.throughline/{review-reports,work-queue/completed,wiki/log.md}; never fixes code
codex_note = Handoff (Codex has no declarative handoff graph): return the verdict + findings to the Orchestrator; on FAIL it re-tasks the Implementer, on PASS/CONDITIONAL_PASS it advances the slice.
